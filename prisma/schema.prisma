generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  member
}

enum TaskStatus {
  backlog
  todo
  in_progress
  review
  done
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum SprintStatus {
  planning
  active
  completed
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String?  @unique
  passwordHash       String?  @map("password_hash")
  avatar             String
  color              String
  role               Role     @default(member)
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  tasks              Task[]   @relation("Assignee")
  comments           Comment[]

  @@map("users")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String       @default("")
  status      TaskStatus   @default(backlog)
  priority    TaskPriority @default(medium)
  assigneeId  String?      @map("assignee_id")
  assignee    User?        @relation("Assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  sprintId    String?      @map("sprint_id")
  sprint      Sprint?      @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  startDate   DateTime?    @map("start_date") @db.Date
  endDate     DateTime?    @map("end_date") @db.Date
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  comments    Comment[]
  branches    TaskBranch[]
  subtasks    Subtask[]

  @@map("tasks")
}

model Project {
  id            String       @id @default(uuid())
  name          String
  githubOwner   String       @map("github_owner")
  githubRepo    String       @map("github_repo")
  defaultBranch String       @default("main") @map("default_branch")
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now()) @map("created_at")
  branches      TaskBranch[]

  @@unique([githubOwner, githubRepo])
  @@map("projects")
}

model TaskBranch {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  projectId  String   @map("project_id")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branchName String   @map("branch_name")
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([taskId, projectId])
  @@map("task_branches")
}

model Subtask {
  id        String   @id @default(uuid())
  title     String
  done      Boolean  @default(false)
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("subtasks")
}

model Sprint {
  id        String       @id @default(uuid())
  name      String
  goal      String       @default("")
  startDate DateTime     @map("start_date") @db.Date
  endDate   DateTime     @map("end_date") @db.Date
  status    SprintStatus @default(planning)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")
  tasks     Task[]

  @@map("sprints")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  taskId    String   @map("task_id")
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("comments")
}
